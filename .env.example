# Montfort API Configuration

# Server
PORT=3100
NODE_ENV=development
SITE_URL=http://localhost:3000

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=

# Database (uncomment for PostgreSQL - required for production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/montfort

# SMTP (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
